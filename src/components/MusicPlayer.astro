---
import { Icon } from 'astro-icon/components';
import Window from './Window.astro';
import fs from 'node:fs';
import path from 'node:path';

const musicDir = path.join(process.cwd(), 'public', 'music');
const extensions = ['.mp3', '.ogg', '.wav', '.m4a', '.flac'];
let trackList: string[] = [];

if (fs.existsSync(musicDir)) {
  trackList = fs.readdirSync(musicDir)
    .filter(f => extensions.includes(path.extname(f).toLowerCase()))
    .map(f => `/music/${f}`);
}
---

<Window title="Music Player">
  <Fragment slot="title">
    <Icon name="mdi:music-note" size={14} />
    Music Player
  </Fragment>
  <div class="player" data-tracks={JSON.stringify(trackList)}>
    <div data-animate class="player-display">
      <span class="now-playing" id="now-playing">Loading...</span>
    </div>
    <div data-animate class="player-controls">
      <button class="ctrl-btn" id="prev-btn" aria-label="Previous">
        <Icon name="mdi:skip-previous" size={16} />
      </button>
      <button class="ctrl-btn play-btn" id="play-btn" aria-label="Play/Pause">
        <Icon name="mdi:play" size={18} />
      </button>
      <button class="ctrl-btn" id="next-btn" aria-label="Next">
        <Icon name="mdi:skip-next" size={16} />
      </button>
    </div>
    <div data-animate class="volume-row">
      <Icon name="mdi:volume-low" size={14} />
      <input
        type="range"
        id="volume-slider"
        min="0"
        max="100"
        value="5"
        class="volume-slider"
        aria-label="Volume"
      />
      <Icon name="mdi:volume-high" size={14} />
    </div>
    <div data-animate class="progress-row">
      <span class="time" id="current-time">0:00</span>
      <div class="progress-bar" id="progress-bar">
        <div class="progress-fill" id="progress-fill"></div>
      </div>
      <span class="time" id="duration">0:00</span>
    </div>
  </div>
</Window>

<script>
  const player = document.querySelector('.player') as HTMLElement;
  const audio = new Audio();
  const playBtn = document.getElementById('play-btn');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const volumeSlider = document.getElementById('volume-slider') as HTMLInputElement;
  const nowPlaying = document.getElementById('now-playing');
  const progressBar = document.getElementById('progress-bar');
  const progressFill = document.getElementById('progress-fill');
  const currentTimeEl = document.getElementById('current-time');
  const durationEl = document.getElementById('duration');

  let currentIndex = 0;
  let isPlaying = false;
  let targetVolume = 0.05;
  let fadeTimer: ReturnType<typeof setInterval> | null = null;

  // Tracks discovered at build time
  const allTracks: string[] = JSON.parse(player?.dataset.tracks || '[]');

  function formatTime(seconds: number): string {
    const m = Math.floor(seconds / 60);
    const s = Math.floor(seconds % 60);
    return `${m}:${s.toString().padStart(2, '0')}`;
  }

  // Shuffle
  for (let i = allTracks.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [allTracks[i], allTracks[j]] = [allTracks[j], allTracks[i]];
  }

  function displayName(src: string): string {
    const name = decodeURIComponent(src.split('/').pop() || 'Unknown');
    return name.replace(/\.[^.]+$/, '').replace(/_/g, ' ');
  }

  function loadTrack(index: number) {
    if (allTracks.length === 0) return;
    currentIndex = index;
    audio.src = allTracks[currentIndex];
    if (nowPlaying) nowPlaying.textContent = `♪ ${displayName(allTracks[currentIndex])}`;
    if (progressFill) progressFill.style.width = '0%';
    if (currentTimeEl) currentTimeEl.textContent = '0:00';
    if (durationEl) durationEl.textContent = '0:00';
  }

  const PAUSE_ICON = '<svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M14,19H18V5H14M6,19H10V5H6V19Z"/></svg>';
  const PLAY_ICON  = '<svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M8,5.14V19.14L19,12.14L8,5.14Z"/></svg>';

  function setPlayingState(playing: boolean) {
    isPlaying = playing;
    if (playBtn) playBtn.innerHTML = playing ? PAUSE_ICON : PLAY_ICON;
  }

  function play() {
    const promise = audio.play();
    if (promise !== undefined) {
      promise
        .then(() => setPlayingState(true))
        .catch(() => setPlayingState(false)); // autoplay blocked or interrupted
    } else {
      setPlayingState(true);
    }
  }

  function pause() {
    audio.pause();
    setPlayingState(false);
  }

  const FADE_MS = 400;
  const FADE_STEPS = 20;

  function fadeOut(callback: () => void) {
    if (fadeTimer) clearInterval(fadeTimer);
    if (audio.volume <= 0) { callback(); return; }
    const startVol = audio.volume;
    let tick = 0;
    fadeTimer = setInterval(() => {
      tick++;
      if (tick >= FADE_STEPS) {
        audio.volume = 0;
        clearInterval(fadeTimer!);
        fadeTimer = null;
        callback();
      } else {
        audio.volume = startVol * (1 - tick / FADE_STEPS);
      }
    }, FADE_MS / FADE_STEPS);
  }

  function fadeIn() {
    if (fadeTimer) clearInterval(fadeTimer);
    audio.volume = 0;
    let tick = 0;
    fadeTimer = setInterval(() => {
      tick++;
      if (tick >= FADE_STEPS) {
        audio.volume = targetVolume;
        clearInterval(fadeTimer!);
        fadeTimer = null;
      } else {
        audio.volume = targetVolume * (tick / FADE_STEPS);
      }
    }, FADE_MS / FADE_STEPS);
  }

  function transition(index: number) {
    if (!isPlaying) {
      loadTrack(index);
      return;
    }
    fadeOut(() => {
      loadTrack(index);
      const promise = audio.play();
      if (promise !== undefined) {
        promise.then(() => { setPlayingState(true); fadeIn(); }).catch(() => setPlayingState(false));
      } else {
        setPlayingState(true);
        fadeIn();
      }
    });
  }

  function nextTrack() { transition((currentIndex + 1) % allTracks.length); }
  function prevTrack() { transition((currentIndex - 1 + allTracks.length) % allTracks.length); }

  // Init — load track but don't play yet; wait for user interaction via intro
  if (allTracks.length === 0) {
    if (nowPlaying) nowPlaying.textContent = 'No tracks found';
  } else {
    audio.volume = targetVolume;
    loadTrack(0);
    document.addEventListener('profile:enter', () => play(), { once: true });
  }

  // Hide volume slider on iOS (volume is read-only)
  const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);
  if (isIOS) {
    document.querySelector('.volume-row')?.remove();
  }

  // Controls
  playBtn?.addEventListener('click', () => { isPlaying ? pause() : play(); });
  prevBtn?.addEventListener('click', prevTrack);
  nextBtn?.addEventListener('click', nextTrack);
  volumeSlider?.addEventListener('input', () => {
    targetVolume = parseInt(volumeSlider.value) / 100;
    audio.volume = targetVolume;
  });

  audio.addEventListener('timeupdate', () => {
    if (audio.duration) {
      const pct = (audio.currentTime / audio.duration) * 100;
      if (progressFill) progressFill.style.width = `${pct}%`;
      if (currentTimeEl) currentTimeEl.textContent = formatTime(audio.currentTime);
    }
  });

  audio.addEventListener('loadedmetadata', () => {
    if (durationEl) durationEl.textContent = formatTime(audio.duration);
  });

  audio.addEventListener('ended', nextTrack);

  progressBar?.addEventListener('click', (e) => {
    const rect = progressBar.getBoundingClientRect();
    const pct = (e.clientX - rect.left) / rect.width;
    audio.currentTime = pct * audio.duration;
  });
</script>

<style>
  .player {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .player-display {
    background: rgba(255, 255, 255, 0.5);
    border: 2px inset rgba(120, 155, 200, 0.5);
    padding: 6px 8px;
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: var(--color-body);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .player-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
  }

  .ctrl-btn {
    background: rgba(255, 255, 255, 0.6);
    border: 1.5px solid rgba(140, 170, 210, 0.5);
    color: var(--color-body);
    width: 30px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius: 1px;
    transition: background 0.15s;
  }

  .ctrl-btn:hover {
    background: rgba(122, 168, 212, 0.25);
  }

  .play-btn {
    width: 36px;
    height: 30px;
  }

  .volume-row {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--color-secondary);
  }

  .volume-slider {
    flex: 1;
    height: 4px;
    appearance: none;
    -webkit-appearance: none;
    background: rgba(140, 170, 210, 0.3);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }

  .volume-slider::-webkit-slider-thumb {
    appearance: none;
    -webkit-appearance: none;
    width: 12px;
    height: 12px;
    background: var(--color-title-bar-start);
    border-radius: 50%;
    cursor: pointer;
  }

  .volume-slider::-moz-range-thumb {
    width: 12px;
    height: 12px;
    background: var(--color-title-bar-start);
    border-radius: 50%;
    border: none;
    cursor: pointer;
  }

  .progress-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .time {
    font-size: 9px;
    font-family: 'Courier New', monospace;
    color: var(--color-secondary);
    min-width: 28px;
    text-align: center;
  }

  .progress-bar {
    flex: 1;
    height: 6px;
    background: rgba(140, 170, 210, 0.25);
    border: 1px inset rgba(120, 155, 200, 0.4);
    cursor: pointer;
    position: relative;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-title-bar-start), var(--color-title-bar-end));
    width: 0%;
    transition: width 0.3s linear;
  }
</style>
