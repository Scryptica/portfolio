---
interface Props {
  title: string;
  showThemeToggle?: boolean;
}

const { title, showThemeToggle = false } = Astro.props;
---

<div class="window">
  <div class="title-bar">
    <span class="title-bar-text">
      <slot name="title">{title}</slot>
    </span>
    <div class="title-buttons">
      {showThemeToggle && (
        <div class="title-btn theme-toggle" role="button" aria-label="Toggle dark mode" tabindex="0">
          <span class="toggle-icon light-icon">&#9788;</span>
          <span class="toggle-icon dark-icon">&#9790;</span>
        </div>
      )}
      <div class="title-btn" aria-hidden="true">&#8722;</div>
      <div class="title-btn" aria-hidden="true">&#9633;</div>
      <div class="title-btn" aria-hidden="true">&#215;</div>
    </div>
  </div>
  <div class="window-body">
    <slot />
  </div>
</div>

<style>
  .window {
    background: var(--color-glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 2px solid var(--color-glass-border);
    box-shadow:
      4px 4px 16px var(--color-glass-shadow),
      inset 0 0 0 1px var(--color-glass-inner);
    width: 100%;
  }

  .title-bar {
    background: linear-gradient(90deg, var(--color-title-bar-start), var(--color-title-bar-end));
    padding: 4px 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .title-bar-text {
    color: white;
    font-size: 12px;
    font-weight: bold;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.25);
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .title-buttons {
    display: flex;
    gap: 3px;
  }

  .title-btn {
    background: var(--color-btn-bg);
    border: 1px solid var(--color-btn-border);
    width: 18px;
    height: 16px;
    text-align: center;
    font-size: 11px;
    line-height: 16px;
    border-radius: 1px;
    color: var(--color-body);
  }

  .theme-toggle {
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .toggle-icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    transition: opacity 0.2s;
  }

  :global(:root) .dark-icon { opacity: 0; }
  :global(:root) .light-icon { opacity: 1; }
  :global(:root.dark) .dark-icon { opacity: 1; }
  :global(:root.dark) .light-icon { opacity: 0; }

  .window-body {
    padding: 24px;
  }

</style>

<script>
  const toggle = document.querySelector('.theme-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      window.dispatchEvent(new Event('theme:toggle'));
    });
  }
</script>
