---
import { Icon } from 'astro-icon/components';
import Window from './Window.astro';
---

<Window title="вҳҶ Scryptica's Portfolio">
  <!-- Hero -->
  <div class="hero-content">
    <img
      data-animate
      class="avatar"
      src="https://avatars.githubusercontent.com/u/198969065?v=4"
      alt="Scryptica's avatar"
      width="80"
      height="80"
    />
    <div class="hero-text">
      <h1 data-animate>
        Scryptica вҳҶ <span class="wave" aria-label="waving hand">рҹ‘Ӣ</span>
      </h1>
      <p data-animate class="subtitle">Welcome to my corner of the internet</p>
      <div data-animate class="social-links">
        <a href="https://github.com/Scryptica" target="_blank" rel="noopener noreferrer" class="social-link">
          <Icon name="mdi:github" size={16} />
          GitHub
        </a>
      </div>
    </div>
  </div>

  <!-- Win98 separator -->
  <hr data-animate class="win98-divider" />

  <!-- About Me -->
  <div data-animate class="about-header">
    <Icon name="mdi:folder-open" size={14} />
    <span>C:\Users\Scryptica\about_me.txt</span>
  </div>
  <div data-animate class="about-text">
    <p class="about-deco">в”Җв”Җв”Җ пҪҘ пҪЎпҫҹвҳҶ: *.вҳҪ .* :вҳҶпҫҹ. в”Җв”Җв”Җ</p>
    <p>
      Hey! I am Scryptica ~ a hobby programmer who enjoys developing
      cool websites and backend services.
      I am always ready to experiment and create new projects from scratch.
      Oh, and I have a slight obsession with <span class="cc-domain">.cc domains</span>... don't judge me.
      Quality and design are always my top priorities.
    </p>
    <p class="about-deco">в”Җв”Җв”Җ пҪҘ пҪЎпҫҹвҳҶ: *.вҳҪ .* :вҳҶпҫҹ. в”Җв”Җв”Җ</p>
  </div>

  <!-- Footer -->
  <div data-animate class="hero-footer">
    <span class="footer-chip">
      <Icon name="mdi:clock-outline" size={14} />
      <span id="spain-time">--:--:--</span>
    </span>
    <span class="footer-chip">
      <Icon name="mdi:eye-outline" size={14} />
      <span id="visitor-count">-</span>
    </span>
  </div>
</Window>

<script>
  import { gsap } from 'gsap';

  const wave = document.querySelector('.wave');
  if (wave) {
    gsap.to(wave, {
      keyframes: [
        { rotation: 14, duration: 0.15 },
        { rotation: -8, duration: 0.15 },
        { rotation: 14, duration: 0.15 },
        { rotation: -4, duration: 0.15 },
        { rotation: 10, duration: 0.15 },
        { rotation: 0, duration: 0.3 },
      ],
      ease: 'power1.inOut',
      repeat: -1,
      repeatDelay: 1.5,
      transformOrigin: '70% 70%',
    });
  }

  function updateSpainTime() {
    const el = document.getElementById('spain-time');
    if (el) {
      el.textContent = new Date().toLocaleTimeString('es-ES', {
        timeZone: 'Europe/Madrid',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
      });
    }
  }
  updateSpainTime();
  setInterval(updateSpainTime, 1000);

  async function trackVisitor() {
    try {
      const res = await fetch('https://api.scryptica.cc/visitors', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await res.json();
      const el = document.getElementById('visitor-count');
      if (el) el.textContent = data.count.toLocaleString();
    } catch {
      // silent fail вҖ” visitor count is non-critical
    }
  }
  trackVisitor();
</script>

<style>
  .hero-content {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 3px solid var(--color-avatar-border);
    box-shadow: 0 4px 14px var(--color-avatar-shadow);
    object-fit: cover;
    flex-shrink: 0;
  }

  h1 {
    font-size: 22px;
    color: var(--color-primary);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .wave {
    display: inline-block;
    font-size: 24px;
  }

  .subtitle {
    font-size: 13px;
    color: var(--color-secondary);
    margin-top: 4px;
  }

  .social-links {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }

  .social-link {
    background: var(--color-social-bg);
    border: 1px solid var(--color-social-border);
    padding: 4px 10px;
    font-size: 11px;
    color: var(--color-secondary);
    text-decoration: none;
    border-radius: 2px;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: background 0.2s;
  }

  .social-link:hover {
    background: var(--color-social-hover);
  }

  /* Win98 divider */
  .win98-divider {
    border: none;
    border-top: 1px solid var(--color-divider-top);
    border-bottom: 1px solid var(--color-divider-bottom);
    margin: 20px 0;
  }

  /* About section */
  .about-header {
    font-size: 11px;
    font-family: 'Courier New', monospace;
    color: var(--color-body);
    background: var(--color-inset-bg);
    border: 2px inset var(--color-inset-border);
    padding: 4px 8px;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .about-text p {
    font-size: 13px;
    line-height: 1.7;
    color: var(--color-body);
  }

  .cc-domain {
    color: var(--color-primary);
    font-weight: bold;
  }

  .about-deco {
    text-align: center;
    font-size: 11px;
    color: var(--color-title-bar-start);
    opacity: 0.6;
    letter-spacing: 2px;
  }

  /* Footer */
  .hero-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid var(--color-divider-top);
  }

  .footer-chip {
    font-size: 11px;
    color: var(--color-secondary);
    display: flex;
    align-items: center;
    gap: 4px;
    cursor: default;
  }

  @media (max-width: 640px) {
    .avatar {
      width: 60px;
      height: 60px;
    }
    h1 {
      font-size: 18px;
    }
  }
</style>
