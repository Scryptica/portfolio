---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Scryptica's Portfolio" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <script is:inline>
      (function() {
        if (localStorage.getItem('theme') === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  @import '../styles/global.css';
</style>

<script>
  import { gsap } from 'gsap';

  const THEME_VARS = [
    '--color-bg', '--color-grid', '--color-primary', '--color-secondary',
    '--color-body', '--color-title-bar-start', '--color-title-bar-end',
    '--color-glass-bg', '--color-glass-border', '--color-glass-shadow',
    '--color-glass-inner', '--color-btn-bg', '--color-btn-border',
    '--color-inset-bg', '--color-inset-border', '--color-social-bg',
    '--color-social-border', '--color-social-hover', '--color-divider-top',
    '--color-divider-bottom', '--color-avatar-border', '--color-avatar-shadow',
    '--color-status-dot-border', '--color-slider-track', '--color-progress-bg',
    '--color-progress-border', '--color-ctrl-bg', '--color-ctrl-border',
    '--color-ctrl-hover', '--color-radial-1', '--color-radial-2',
    '--color-particle-star-shadow', '--color-particle-bubble-border',
  ];

  let activeTween: gsap.core.Tween | null = null;

  function transitionTheme(toDark: boolean) {
    const root = document.documentElement;

    if (activeTween) {
      activeTween.kill();
    }

    // Read current computed values before class change
    const from: Record<string, string> = {};
    const computed = getComputedStyle(root);
    THEME_VARS.forEach(v => {
      from[v] = computed.getPropertyValue(v).trim();
    });

    // Apply target class so CSS knows the destination
    root.classList.toggle('dark', toDark);

    // Use runtime palette if available, otherwise read from CSS
    const runtimePalette = toDark
      ? (window as any).__darkPalette
      : (window as any).__lightPalette;

    const to: Record<string, string> = {};
    if (runtimePalette) {
      THEME_VARS.forEach(v => { to[v] = runtimePalette[v] || getComputedStyle(root).getPropertyValue(v).trim(); });
    } else {
      const newComputed = getComputedStyle(root);
      THEME_VARS.forEach(v => { to[v] = newComputed.getPropertyValue(v).trim(); });
    }

    // Set inline styles to FROM values to prevent visual snap
    THEME_VARS.forEach(v => root.style.setProperty(v, from[v]));

    // Build GSAP target with all destination values
    const gsapTarget: Record<string, string | number> = {};
    THEME_VARS.forEach(v => { gsapTarget[v] = to[v]; });

    activeTween = gsap.to(root, {
      ...gsapTarget,
      duration: 1.2,
      ease: 'power2.inOut',
      onComplete: () => {
        // Keep runtime palette inline styles, only clear if no API palette loaded
        const palette = toDark
          ? (window as any).__darkPalette
          : (window as any).__lightPalette;
        if (palette) {
          THEME_VARS.forEach(v => root.style.setProperty(v, palette[v] || ''));
        } else {
          THEME_VARS.forEach(v => root.style.removeProperty(v));
        }
        activeTween = null;
      },
    });
  }

  // Listen for theme toggle from the Window title bar button
  window.addEventListener('theme:toggle', () => {
    const isDark = document.documentElement.classList.contains('dark');
    const newIsDark = !isDark;
    localStorage.setItem('theme', newIsDark ? 'dark' : 'light');
    transitionTheme(newIsDark);
  });

  // --- Runtime palette from API ---

  function hsl(h: number, s: number, l: number) {
    return `hsl(${Math.round(h)}, ${Math.round(s)}%, ${Math.round(l)}%)`;
  }
  function hsla(h: number, s: number, l: number, a: number) {
    return `hsla(${Math.round(h)}, ${Math.round(s)}%, ${Math.round(l)}%, ${a})`;
  }

  function buildPalette(colors: { h: number; s: number; l: number }[]) {
    const [dominant, secondary, accent] = colors;
    const H = dominant.h;
    const H2 = secondary.h;
    const H3 = accent.h;
    const S = Math.min(dominant.s, 70);

    const light: Record<string, string> = {
      '--color-bg':                    hsl(H, S * 0.6, 88),
      '--color-grid':                  hsla(H, S * 0.5, 72, 0.35),
      '--color-primary':               hsl(H, S * 0.7, 38),
      '--color-secondary':             hsl(H, S * 0.5, 48),
      '--color-body':                  hsl(H, S * 0.55, 42),
      '--color-title-bar-start':       hsl(H, S * 0.55, 65),
      '--color-title-bar-end':         hsl(H2, S * 0.45, 78),
      '--color-glass-bg':              'rgba(255, 255, 255, 0.55)',
      '--color-glass-border':          hsla(H, S * 0.5, 69, 0.5),
      '--color-glass-shadow':          hsla(H, S * 0.6, 59, 0.2),
      '--color-glass-inner':           'rgba(255, 255, 255, 0.4)',
      '--color-btn-bg':                'rgba(255, 255, 255, 0.65)',
      '--color-btn-border':            hsla(H, S * 0.5, 69, 0.5),
      '--color-inset-bg':              'rgba(255, 255, 255, 0.5)',
      '--color-inset-border':          hsla(H, S * 0.55, 63, 0.5),
      '--color-social-bg':             hsla(H, S * 0.6, 65, 0.15),
      '--color-social-border':         hsla(H, S * 0.6, 65, 0.3),
      '--color-social-hover':          hsla(H, S * 0.6, 65, 0.3),
      '--color-divider-top':           hsla(H, S * 0.5, 57, 0.3),
      '--color-divider-bottom':        'rgba(255, 255, 255, 0.6)',
      '--color-avatar-border':         hsla(H, S * 0.6, 65, 0.4),
      '--color-avatar-shadow':         hsla(H, S * 0.55, 59, 0.25),
      '--color-status-dot-border':     'rgba(255, 255, 255, 0.55)',
      '--color-slider-track':          hsla(H, S * 0.5, 69, 0.3),
      '--color-progress-bg':           hsla(H, S * 0.5, 69, 0.25),
      '--color-progress-border':       hsla(H, S * 0.55, 63, 0.4),
      '--color-ctrl-bg':               'rgba(255, 255, 255, 0.6)',
      '--color-ctrl-border':           hsla(H, S * 0.5, 69, 0.5),
      '--color-ctrl-hover':            hsla(H, S * 0.6, 65, 0.25),
      '--color-radial-1':              hsla(H, S * 0.4, 89, 0.4),
      '--color-radial-2':              hsla(H2, S * 0.45, 84, 0.3),
      '--color-particle-star-shadow':  hsla(H3, S * 0.5, 60, 0.6),
      '--color-particle-bubble-border': hsla(H2, S * 0.4, 70, 0.3),
    };

    const dark: Record<string, string> = {
      '--color-bg':                    hsl(H, S * 0.5, 10),
      '--color-grid':                  hsla(H, S * 0.6, 59, 0.12),
      '--color-primary':               hsl(H, S * 0.55, 72),
      '--color-secondary':             hsl(H, S * 0.55, 62),
      '--color-body':                  hsl(H, S * 0.4, 60),
      '--color-title-bar-start':       hsl(H, S * 0.45, 30),
      '--color-title-bar-end':         hsl(H2, S * 0.4, 35),
      '--color-glass-bg':              hsla(H, S * 0.4, 10, 0.75),
      '--color-glass-border':          hsla(H, S * 0.55, 51, 0.35),
      '--color-glass-shadow':          'rgba(0, 0, 0, 0.4)',
      '--color-glass-inner':           hsla(H, S * 0.55, 51, 0.15),
      '--color-btn-bg':                hsla(H, S * 0.35, 20, 0.65),
      '--color-btn-border':            hsla(H, S * 0.55, 51, 0.5),
      '--color-inset-bg':              hsla(H, S * 0.4, 8, 0.6),
      '--color-inset-border':          hsla(H, S * 0.5, 43, 0.4),
      '--color-social-bg':             hsla(H, S * 0.45, 30, 0.25),
      '--color-social-border':         hsla(H, S * 0.5, 43, 0.3),
      '--color-social-hover':          hsla(H, S * 0.5, 43, 0.4),
      '--color-divider-top':           hsla(H, S * 0.5, 43, 0.3),
      '--color-divider-bottom':        hsla(H, S * 0.55, 51, 0.15),
      '--color-avatar-border':         hsla(H, S * 0.55, 55, 0.4),
      '--color-avatar-shadow':         'rgba(0, 0, 0, 0.35)',
      '--color-status-dot-border':     hsla(H, S * 0.4, 10, 0.75),
      '--color-slider-track':          hsla(H, S * 0.5, 43, 0.35),
      '--color-progress-bg':           hsla(H, S * 0.5, 43, 0.25),
      '--color-progress-border':       hsla(H, S * 0.5, 43, 0.35),
      '--color-ctrl-bg':               hsla(H, S * 0.35, 20, 0.6),
      '--color-ctrl-border':           hsla(H, S * 0.55, 51, 0.4),
      '--color-ctrl-hover':            hsla(H, S * 0.5, 43, 0.3),
      '--color-radial-1':              hsla(H, S * 0.4, 18, 0.4),
      '--color-radial-2':              hsla(H2, S * 0.35, 14, 0.3),
      '--color-particle-star-shadow':  hsla(H3, S * 0.5, 50, 0.5),
      '--color-particle-bubble-border': hsla(H2, S * 0.4, 55, 0.25),
    };

    return { light, dark };
  }

  async function applyRuntimePalette() {
    try {
      const res = await fetch('https://api.scryptica.cc/avatar/colors');
      const data = await res.json();
      if (!data.colors || data.colors.length < 3) return;

      const { light, dark } = buildPalette(data.colors);
      const isDark = document.documentElement.classList.contains('dark');
      const palette = isDark ? dark : light;

      // Apply as inline styles on :root (overrides the CSS file)
      const root = document.documentElement;
      for (const [key, value] of Object.entries(palette)) {
        root.style.setProperty(key, value);
      }

      // Store both palettes for theme toggle transitions
      (window as any).__lightPalette = light;
      (window as any).__darkPalette = dark;
    } catch {
      // Silent fail — build-time palette remains as fallback
    }
  }

  applyRuntimePalette();
</script>
